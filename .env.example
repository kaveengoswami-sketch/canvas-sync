# Copy to .env for LOCAL testing only. Never commit the real .env (it's gitignored).
# In GitHub these go in Settings -> Secrets and variables -> Actions, not here.

# One token per school. The variable NAME must match "token_env" in config.json.
CANVAS_WVM_TOKEN=your_wvm_canvas_token
CANVAS_BERK_TOKEN=your_berkeley_canvas_token

TODOIST_TOKEN=your_todoist_api_token

# Optional: ntfy.sh topic for grade-posted push notifications.
# Pick a long, random, secret string (anyone who knows it can read your alerts).
NTFY_TOPIC=

# Optional overrides
# DRY_RUN=1   # read everything, write nothing
